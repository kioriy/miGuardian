<MainScreen>:
    Screen:
        MDTextField:
            id: barcode_input
            hint_text: 'Introduce el código de barras'
            pos_hint: {'center_x': 0.5, 'center_y': 0.4}
            size_hint: (0.7, 0.1)
            opacity: 0.0
            on_text_validate: app.show_student_info()

        Image:
            id: student_photo
            pos_hint: {'center_x': 0.5, 'center_y': 0.8}
            size_hint: (0.5, 0.5)
            source: 'assets/placeholder.jpeg'  # Imagen por defecto

        MDLabel:
            id: student_info
            font_size: 20
            pos_hint: {'center_x': 0.7, 'center_y': 0.22}
            theme_text_color: 'Primary'

        MDLabel:
            id: status_message
            font_style: 'H6'
            pos_hint: {'center_x': 0.7, 'center_y': 0.070}
            theme_text_color: 'Secondary'

        MDIcon:
            id: status_icon
            pos_hint: {'x': 0.9, 'y': 0.02}
            size_hint: (None, None)
            icon: 'door-open'  # valor por defecto, cambiarás esto en el código
            theme_text_color: 'Custom'
            font_size: "64sp"
            text_color: (0, 1, 0, 1)  # verde por defecto, cambiarás esto en el código
        
        MDFloatingActionButton:
            text: "Cambiar pantalla"
            pos_hint: {'x': 0.02, 'y': 0.02}
            elevation: 0
            #pos: '200dp','500dp'
            size_hint: (None,None)
            size: '120dp','80dp'
            md_bg_color: "#FB5252"#app.theme_cls.primary_color 
            icon: "monitor-multiple"
            on_press: app.switch_screen()

        MDRectangleFlatIconButton:
            icon: "food"
            icon_size: "34sp"
            text: "mi Tiendita"
            elevation: 0
            #theme_text_color: "Custom"
            text_color: "white"
            #line_color: "black"
            #theme_icon_color: "Custom"
            icon_color: "white"
            md_bg_color: app.theme_cls.primary_color
            pos_hint: {"top": 0.98, "x": 0.02}
            #set_size: (100sp, 100sp)
            size_hint: (0.2, 0.08)
            on_press: app.switch_form()

        MDRectangleFlatIconButton:
            icon: "human-baby-changing-table"
            icon_size: "34sp"
            text: "Bitacora"
            elevation: 0

            #theme_text_color: "Custom"
            text_color: "white"
            #line_color: "black"
            #theme_icon_color: "Custom"
            icon_color: "white"
            md_bg_color: app.theme_cls.primary_color
            pos_hint: {"top": 0.89, "x": 0.02}
            #set_size: (100sp, 100sp)
            size_hint: (0.2, 0.08)
            #on_press: app.switch_form()

        MDFloatingActionButton:
            icon: 'power'
            md_bg_color: "#FB5252"
            elevation: 0
            pos_hint: {"top": 0.98, "x": 0.92}
            on_release: app.shutdown_raspberry()

<StoreScreen>:
    BoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            title: 'mi Tiendita'
            left_action_items: [['arrow-left', lambda x: app.switch_form()]]
            # Asociamos el evento on_press con el método switch_form
            on_action_button: app.switch_form()
            
        MDTextField:
            id: barcode_input_store
            hint_text: 'Introduce el código del para registrar desayuno'
            pos_hint: {'center_x': 0.5}
            size_hint_x: 0.8
            on_text_validate: root.register_new_breakfast(self.text)  # Esta función registrará el desayuno para el estudiante

        ScrollView:
            MDList:
                id: breakfast_student_list
            